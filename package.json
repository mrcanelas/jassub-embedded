{
  "name": "@mrcanelas/jassub-embedded",
  "version": "2.5.3",
  "description": "The Fastest JavaScript SSA/ASS Subtitle Renderer For Browsers",
  "main": "dist/jassubBundle.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/jassubBundle.js",
    "dist/jassubAssets.js",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --noCheck",
    "build:worker": "esbuild dist/worker/worker.js --bundle --platform=browser --format=esm --target=es2017 --supported:import-meta=true --outfile=dist/worker/jassubWorkerBundle.js",
    "build:assets": "node scripts/build-assets.js",
    "build:bundle": "esbuild dist/jassub.js --bundle --platform=browser --format=cjs --target=es2020 --outfile=dist/jassubBundle.js --external:fs --external:path",
    "build:embedded": "npm run build && npm run build:worker && npm run build:assets && npm run build:bundle",
    "prepare": "npm run build:embedded"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrcanelas/jassub-embedded.git"
  },
  "keywords": [
    "libass",
    "subtitle",
    "wasm",
    "emscripten",
    "ASS",
    "WebAssembly",
    "subtitles",
    "webgpu",
    "webgl2",
    "typescript"
  ],
  "author": "mrcanelas",
  "license": "LGPL-2.1-or-later AND (FTL OR GPL-2.0-or-later) AND MIT AND MIT-Modern-Variant AND ISC AND NTP AND Zlib AND BSL-1.0",
  "bugs": {
    "url": "https://github.com/mrcanelas/jassub-embedded/issues"
  },
  "homepage": "https://github.com/mrcanelas/jassub-embedded",
  "dependencies": {
    "abslink": "^1.2.2",
    "lfa-ponyfill": "^1.1.0",
    "rvfc-polyfill": "^1.0.8",
    "throughput": "^1.0.2"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.28.0",
    "eslint-config-standard-universal": "^1.0.9",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
}